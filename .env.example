# AutoSecAudit Docker Compose environment template
# Copy to `.env` and fill the required values.

# -----------------------------
# Container runtime / ports
# -----------------------------
AUTOSECAUDIT_CONTAINER_USER=autosec
AUTOSECAUDIT_WEB_PORT=18080
# Used by CLI-mode browser OAuth callback (not required for Web UI OAuth redirect flow)
AUTOSECAUDIT_OAUTH_CALLBACK_PORT=8765

# -----------------------------
# Optional proxy settings
# -----------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost

# -----------------------------
# Optional API-key based LLM access (OpenAI SDK or compatible gateways)
# Leave empty if using Codex OAuth browser login only.
# -----------------------------
OPENAI_API_KEY=
OPENAI_ACCESS_TOKEN=

# -----------------------------
# Optional Telegram notifier token
# -----------------------------
LYNOLZ_BOT_TOKEN=
AUTOSECAUDIT_WEB_API_TOKEN=
AUTOSECAUDIT_WEB_DEFAULT_ADMIN_USERNAME=admin
AUTOSECAUDIT_WEB_DEFAULT_ADMIN_PASSWORD=ChangeMe-Admin-2026!
AUTOSECAUDIT_WEB_DEFAULT_ADMIN_DISPLAY_NAME=
# REQUIRED: set a unique secret with at least 32 characters before deployment.
AUTOSECAUDIT_WEB_JWT_SECRET=ChangeMe-JWT-Secret-Please-Rotate-2026
AUTOSECAUDIT_WEB_BOOTSTRAP_TOKEN_TTL_SECONDS=3600
AUTOSECAUDIT_WEB_JWT_TTL_SECONDS=28800
AUTOSECAUDIT_WEB_REFRESH_TTL_SECONDS=1209600
AUTOSECAUDIT_WEB_MAX_JOBS=200
AUTOSECAUDIT_WEB_MAX_RUNNING_JOBS=4
AUTOSECAUDIT_CACHE_BACKEND=memory
AUTOSECAUDIT_REDIS_PASSWORD=ChangeMe-Redis-2026!
AUTOSECAUDIT_REDIS_URL=redis://:ChangeMe-Redis-2026!@autosecaudit-redis:6379/0
AUTOSECAUDIT_WEB_CORS_ALLOW_ORIGINS=
AUTOSECAUDIT_WEB_ENABLE_METRICS=1
AUTOSECAUDIT_WEB_ENFORCE_HTTPS=0
AUTOSECAUDIT_WEB_TRUST_PROXY_HEADERS=0
AUTOSECAUDIT_WEB_HSTS_MAX_AGE_SECONDS=31536000
AUTOSECAUDIT_WEB_HSTS_INCLUDE_SUBDOMAINS=1
AUTOSECAUDIT_WEB_HSTS_PRELOAD=0
AUTOSECAUDIT_WEB_RATE_LIMIT_BACKEND=auto
AUTOSECAUDIT_WEB_RATE_LIMIT_AUTH_LOGIN=5/60
AUTOSECAUDIT_WEB_RATE_LIMIT_AUTH_REFRESH=20/300
AUTOSECAUDIT_WEB_RATE_LIMIT_API_WRITE=120/60
AUTOSECAUDIT_WEB_PASSWORD_MIN_LENGTH=10
AUTOSECAUDIT_WEB_PASSWORD_REQUIRE_MIXED_CASE=1
AUTOSECAUDIT_WEB_PASSWORD_REQUIRE_DIGIT=1
AUTOSECAUDIT_WEB_PASSWORD_REQUIRE_SPECIAL=0

# -----------------------------
# Web console public URL (recommended when behind Nginx / domain / HTTPS)
# Example: https://audit.lynolz.com
# If empty, server will infer callback URL from Host / X-Forwarded-* headers.
# -----------------------------
AUTOSECAUDIT_WEB_PUBLIC_BASE_URL=

# -----------------------------
# Codex OAuth (official login redirect) preset for Web UI "Connect Codex"
# Zero-config mode uses builtin preset (experimental; may break if upstream changes).
# For a stable independent deployment, configure your own legal OAuth endpoints/client_id.
# -----------------------------
AUTOSECAUDIT_CODEX_PROVIDER_ALIAS=codex
AUTOSECAUDIT_CODEX_BASE_URL=https://api.openai.com/v1
AUTOSECAUDIT_CODEX_OAUTH_BUILTIN_PRESET=1
AUTOSECAUDIT_CODEX_OAUTH_AUTHORIZE_URL=
AUTOSECAUDIT_CODEX_OAUTH_TOKEN_URL=
AUTOSECAUDIT_CODEX_OAUTH_CLIENT_ID=
AUTOSECAUDIT_CODEX_OAUTH_SCOPES=openid,profile,offline_access
AUTOSECAUDIT_CODEX_OAUTH_PROFILE_ID=web
AUTOSECAUDIT_CODEX_OAUTH_PROFILES_FILE=/workspace/config/auth-profiles.json
AUTOSECAUDIT_CODEX_OAUTH_TOKEN_ENV=OPENAI_ACCESS_TOKEN
AUTOSECAUDIT_CODEX_OAUTH_AUTO_REFRESH=1

# -----------------------------
# Docker build toggles (optional)
# 1 = enabled, 0 = disabled
# -----------------------------
INSTALL_NUCLEI=0
NUCLEI_VERSION=3.3.10
INSTALL_PLAYWRIGHT=0
INSTALL_PLAYWRIGHT_BROWSER=0
