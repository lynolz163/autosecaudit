{
  "primary_model": "openai/gpt-4.1-mini",
  "fallback_models": [],
  "default_provider": "openai",
  "request": {
    "temperature": 0.0,
    "max_output_tokens": 1200
  },
  "providers": {
    "openai": {
      "type": "openai_sdk",
      "api_key_env": "OPENAI_API_KEY",
      "timeout_seconds": 300
    }
  },
  "autosecaudit": {
    "default_budget": 50,
    "strict_safe_mode": true,
    "agent_defaults": {
      "max_iterations": 3,
      "global_timeout": 300
    }
  },
  "notifiers": {
    "telegram": {
      "enabled": false,
      "type": "telegram",
      "name": "lynolz_bot",
      "bot_token_env": "LYNOLZ_BOT_TOKEN",
      "chat_id": "<telegram_chat_id>",
      "timeout_seconds": 8,
      "api_base_url": "https://api.telegram.org",
      "gateway_base_url": "",
      "headers": {
        "X-Notifier-Route": "telegram"
      },
      "event_rules": {
        "notify_high_severity": true,
        "notify_budget_block": true,
        "notify_slow_action": true,
        "slow_action_threshold_ms": 15000
      }
    },
    "dingtalk": {
      "enabled": false,
      "type": "dingtalk",
      "name": "secops_dingtalk",
      "webhook_url": "https://oapi.dingtalk.com/robot/send?access_token=<dingtalk_token>",
      "timeout_seconds": 8,
      "headers": {
        "X-Notifier-Route": "dingtalk"
      }
    },
    "wecom": {
      "enabled": false,
      "type": "wecom",
      "name": "secops_wecom",
      "webhook_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=<wecom_key>",
      "timeout_seconds": 8,
      "headers": {
        "X-Notifier-Route": "wecom"
      }
    }
  }
}
