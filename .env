# AutoSecAudit Docker Compose environment
# Edit the REQUIRED items below, then run:
#   docker compose up -d autosecaudit-web

# -----------------------------
# Container runtime / ports
# -----------------------------
AUTOSECAUDIT_CONTAINER_USER=0:0
AUTOSECAUDIT_WEB_PORT=57541
AUTOSECAUDIT_OAUTH_CALLBACK_PORT=8765

# -----------------------------
# Optional proxy settings
# -----------------------------
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost

# -----------------------------
# Optional API-key based LLM access
# -----------------------------
OPENAI_API_KEY=
OPENAI_ACCESS_TOKEN=

# -----------------------------
# Optional Telegram notifier
# -----------------------------
LYNOLZ_BOT_TOKEN=
AUTOSECAUDIT_WEB_DEFAULT_ADMIN_USERNAME=lynolz
AUTOSECAUDIT_WEB_DEFAULT_ADMIN_PASSWORD=nideruomima
AUTOSECAUDIT_WEB_DEFAULT_ADMIN_DISPLAY_NAME=lynolz
AUTOSECAUDIT_WEB_API_TOKEN=
AUTOSECAUDIT_WEB_MAX_JOBS=200
AUTOSECAUDIT_WEB_MAX_RUNNING_JOBS=4

# -----------------------------
# Web console public URL (RECOMMENDED behind reverse proxy / HTTPS)
# Example:
# AUTOSECAUDIT_WEB_PUBLIC_BASE_URL=https://audit.lynolz.com
# -----------------------------
AUTOSECAUDIT_WEB_PUBLIC_BASE_URL=

# -----------------------------
# Codex OAuth preset for Web UI "Connect Codex"
# Zero-config mode uses builtin preset (experimental; may break if upstream changes).
# For a stable independent deployment, configure your own legal OAuth endpoints/client_id.
# -----------------------------
AUTOSECAUDIT_CODEX_PROVIDER_ALIAS=codex
AUTOSECAUDIT_CODEX_BASE_URL=https://api.openai.com/v1
AUTOSECAUDIT_CODEX_OAUTH_BUILTIN_PRESET=1
AUTOSECAUDIT_CODEX_OAUTH_AUTHORIZE_URL=
AUTOSECAUDIT_CODEX_OAUTH_TOKEN_URL=
AUTOSECAUDIT_CODEX_OAUTH_CLIENT_ID=
AUTOSECAUDIT_CODEX_OAUTH_SCOPES=openid,profile,offline_access
AUTOSECAUDIT_CODEX_OAUTH_PROFILE_ID=web
AUTOSECAUDIT_CODEX_OAUTH_PROFILES_FILE=/workspace/config/auth-profiles.json
AUTOSECAUDIT_CODEX_OAUTH_TOKEN_ENV=OPENAI_ACCESS_TOKEN
AUTOSECAUDIT_CODEX_OAUTH_AUTO_REFRESH=1

# -----------------------------
# Optional image build toggles (when building locally)
# -----------------------------
INSTALL_NUCLEI=1
INSTALL_PLAYWRIGHT=1
# Keep Chromium download disabled during image build on low-memory hosts.
# Enable this only when you explicitly need Playwright browser binaries baked into the image.
INSTALL_PLAYWRIGHT_BROWSER=0
NUCLEI_VERSION=3.3.10
